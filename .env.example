# thepdf.ink build-time configuration.
# Copy to `.env` and fill in before running `npm run build` / `npm run deploy`.

# Pro checkout runs through the in-app account flow (sign in → Lemon Squeezy),
# configured with the server-side secrets at the bottom of this file — there are
# no build-time checkout links to set here.

# ── Supabase (accounts + Pro entitlement) ────────────────────────────────────
# From your thepdf.ink Supabase project → Settings → API. These are PUBLIC
# (safe to ship in the browser bundle); RLS protects the data. Leave unset for
# the Tauri desktop build, which has no accounts and unlocks every tool locally.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google AdSense publisher ID, e.g. ca-pub-1234567890123456.
# Leave empty to keep ads off in the React app. (The static content pages in
# /public also carry the AdSense snippet — replace ca-pub-XXXXXXXXXXXXXXXX there.)
VITE_ADSENSE_CLIENT=

# ── Local admin unlock (testing only) ────────────────────────────────────────
# A client-side admin sign-in that unlocks every tool and hides pricing on the
# current device. NOT a security boundary — the check runs in the browser.
# The login is hidden in production unless the page is opened with ?admin.
# Defaults are admin / admin if unset.
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=admin
# Set to "true" to force full access for an entire build (e.g. a QA build).
VITE_ADMIN_MODE=false

# ── App download / store links (per platform) ────────────────────────────────
# Point these at your hosted installers (GitHub Releases, R2/S3, …) or the app
# store listings. When unset, the download buttons fall back to /pricing.
VITE_DOWNLOAD_URL_MACOS=
VITE_DOWNLOAD_URL_WINDOWS=
VITE_DOWNLOAD_URL_LINUX=
VITE_DOWNLOAD_URL_IOS=
VITE_DOWNLOAD_URL_ANDROID=

# ── Server-side secrets (NOT Vite vars — set with `npx wrangler pages secret put <NAME>`
# or in the Cloudflare Pages dashboard → Settings → Environment variables) ──
#
# Supabase server access — used by /api/checkout (verify the caller) and the
# Lemon Squeezy webhook (flip is_pro). The service_role key bypasses RLS, so it
# must NEVER be a VITE_ var / exposed to the browser.
# SUPABASE_URL=<same project URL as VITE_SUPABASE_URL>
# SUPABASE_ANON_KEY=<same anon key as VITE_SUPABASE_ANON_KEY>
# SUPABASE_SERVICE_ROLE_KEY=<service_role key from Settings → API — keep secret>
#
# Payments — Lemon Squeezy (Merchant of Record; collects & remits VAT/sales tax).
# When LEMONSQUEEZY_API_KEY is unset, checkout runs in TEST MODE and grants Pro
# without charging, so the flow is fully demoable locally.
# LEMONSQUEEZY_API_KEY=<API key from Settings → API>
# LEMONSQUEEZY_STORE_ID=<numeric store id>
# LEMONSQUEEZY_VARIANT_ID=<variant id of the $19 "Pro" product>
# LEMONSQUEEZY_WEBHOOK_SECRET=<signing secret; webhook → /api/lemonsqueezy-webhook, event: order_created>
